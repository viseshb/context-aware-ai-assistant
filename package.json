{
  "name": "context-aware-ai-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "Context-Aware AI Assistant — GitHub + Slack + Postgres via MCP",
  "author": "Visesh Bentula",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently --kill-others --names \"API,WEB\" --prefix-colors \"green,blue\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "cd frontend && npm install",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "build": "cd frontend && npm run build",
    "create-admin": "cd backend && python -m app.security.jwt_auth create-admin"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
