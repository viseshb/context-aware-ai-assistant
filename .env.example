# ╔══════════════════════════════════════════════════════════════════╗
# ║         Context-Aware AI Assistant — Environment Config        ║
# ║                                                                ║
# ║  Copy this file to .env and fill in your keys:                 ║
# ║    cp .env.example .env                                        ║
# ║                                                                ║
# ║  Only add keys for providers you want to use.                  ║
# ║  Missing keys = that provider won't appear in the model list.  ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── LLM API Keys ────────────────────────────────────────────────────
# You only need keys for providers you want. All are optional.

# Google Gemini (FREE) — 4 models: 2.5 Flash Lite, 2.5 Flash, 3.1 Flash Lite, 3 Flash
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# NVIDIA NIM (FREE) — 3 models: Llama 4 Maverick, Ministral 14B, Kimi K2
# Get your key: https://build.nvidia.com/ (sign up, go to any model, click "Get API Key")
NVIDIA_API_KEY=

# Anthropic Claude API (PAID) — Claude Sonnet
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (PAID) — GPT-4.1 Mini
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Claude CLI (FREE with Claude Pro/Max subscription)
# Path to the Claude CLI binary. Default "claude" works if it's on your PATH.
# Windows example: C:\Users\yourname\AppData\Roaming\npm\claude.cmd
# Mac/Linux example: /usr/local/bin/claude
CLAUDE_CLI_PATH=claude

# ─── Data Sources ────────────────────────────────────────────────────
# Connect your external data sources. All are optional.

# GitHub — Create a Personal Access Token (classic) with "repo" scope
# Go to: https://github.com/settings/tokens → Generate new token (classic)
# Select scope: "repo" (for private repos) or "public_repo" (public only)
GITHUB_TOKEN=

# Slack — Create a Slack App and get a Bot Token
# Go to: https://api.slack.com/apps → Create New App → OAuth & Permissions
# Required scopes: channels:history, channels:read, search:read
SLACK_BOT_TOKEN=

# PostgreSQL — Connection string to your database
# Format: postgresql://username:password@host:port/database
# URL-encode special chars in password (e.g. @ becomes %40, # becomes %23)
# Example: postgresql://postgres:MyPass%40123@127.0.0.1:5432/mydb
DATABASE_URL=

# ─── Security ────────────────────────────────────────────────────────

# Comma-separated list of allowed GitHub repos (supports wildcards)
# Examples: viseshb/My-Portfolio,viseshb/Interview-Helper,myorg/*
ALLOWED_REPOS_CSV=

# Comma-separated list of allowed Slack channels
ALLOWED_SLACK_CHANNELS_CSV=

# Rate limiting: requests per time window (e.g. 30/minute, 100/hour)
RATE_LIMIT=30/minute

# Maximum characters per chat message
MAX_MESSAGE_LENGTH=10000

# JWT secret for authentication tokens
# Leave empty = auto-generated on each server start (tokens expire on restart)
# Set a value = tokens persist across restarts
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# JWT token expiry in minutes (default: 30 — user must re-login after 30 min idle)
JWT_EXPIRY_MINUTES=30

# Path to SQLite database for user accounts (auto-created)
USERS_DB_PATH=users.db

# ─── Contact Form (Email) ────────────────────────────────────────────
# Powers the "Contact Us" form on the landing page.
# Uses Gmail SMTP. Requires a Gmail App Password (NOT your regular password).
#
# Setup:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Create App Password: https://myaccount.google.com/apppasswords
#   3. App name: "ContextAI" → copy the 16-char password
#   4. Paste below WITHOUT spaces (e.g. abcdefghijklmnop)

CONTACT_EMAIL=visesh66@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── App Settings ────────────────────────────────────────────────────

# CORS allowed origins (comma-separated). Must match your frontend URL.
CORS_ORIGINS_CSV=http://localhost:3000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
